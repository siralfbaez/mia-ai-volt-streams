{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SCADA Telemetry V.1",
  "type": "object",
  "properties": {
    "asset_id": { "type": "string" },
    "tag_name": { "type": "string" },
    "value": { "type": "number" },
    "unit": { "type": "string", "enum": ["F", "PSI", "AMPS", "KV"] },
    "event_timestamp": { "type": "string", "format": "date-time" },
    "quality": { "type": "string", "enum": ["GOOD", "BAD", "UNCERTAIN"] },
    "metadata": {
      "type": "object",
      "properties": {
        "ambient_temp_f": { "type": "number" },
        "load_amps": { "type": "number" },
        "source_gateway": { "type": "string" }
      },
      "required": ["ambient_temp_f", "load_amps"]
    }
  },
  "required": ["asset_id", "value", "unit", "event_timestamp", "metadata"]
}